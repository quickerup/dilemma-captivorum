# ================================================================
# TON Prisoner's Dilemma Bot — Environment Variable Template
# ================================================================
# For local dev: copy to .env (wrangler picks it up automatically)
# For production: use `wrangler secret put <VAR_NAME>` — never commit real values

# --- Telegram ---
TELEGRAM_BOT_TOKEN=          # From @BotFather
TELEGRAM_WEBHOOK_SECRET=     # Random string; used to verify webhook signature

# --- TON Blockchain ---
TON_WALLET_ADDRESS=          # Bot's TON wallet address (EQ...)
TON_WALLET_MNEMONIC=         # 24-word mnemonic phrase, space-separated
TON_API_KEY=                 # toncenter.com/api/v2 API key

# --- Network ---
NETWORK=testnet              # Options: testnet | mainnet
# testnet endpoint: https://testnet.toncenter.com/api/v2
# mainnet endpoint: https://toncenter.com/api/v2
TON_API_ENDPOINT=https://testnet.toncenter.com/api/v2

# --- Game Settings ---
ADMISSION_FEE_NANO=100000000 # Entry fee in nanoTON (default: 0.1 TON)
